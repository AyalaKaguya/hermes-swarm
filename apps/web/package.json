{
  "name": "@hermes-swarm/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start --port 3100",
    "test": "node --import tsx --test \"lib/**/*.test.ts\"",
    "coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"lib/**/*.ts\" \"lib/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const {rmSync}=require('node:fs'); for (const path of ['.next','.next-dev','out','tsconfig.tsbuildinfo']) rmSync(path,{recursive:true,force:true})\""
  },
  "nx": {
    "projectType": "application",
    "tags": ["type:app", "scope:frontend"],
    "targets": {
      "coverage": {
        "command": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"lib/**/*.ts\" \"lib/**/*.test.ts\"",
        "options": {
          "cwd": "apps/web"
        }
      },
      "e2e": {
        "command": "node apps/web/e2e/run-e2e.mjs"
      }
    }
  },
  "dependencies": {
    "@hermes-swarm/core": "workspace:*",
    "@hermes-swarm/rbac-api": "workspace:*",
    "@tailwindcss/postcss": "^4.3.1",
    "ai": "^7.0.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.16",
    "next": "^16.2.9",
    "next-intl": "4.13.1",
    "postcss": "^8.5.15",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.11.2",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
