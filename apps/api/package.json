{
  "name": "@hermes-swarm/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsc && node dist/main.js",
    "migration:generate": "typeorm-ts-node-esm migration:generate -d src/common/database/migration-data-source.ts",
    "migration:run": "typeorm-ts-node-esm migration:run -d src/common/database/migration-data-source.ts",
    "migration:revert": "typeorm-ts-node-esm migration:revert -d src/common/database/migration-data-source.ts",
    "migration:show": "typeorm-ts-node-esm migration:show -d src/common/database/migration-data-source.ts",
    "seed:development": "tsx src/common/database/seed/development-seed.cli.ts",
    "openapi:generate": "node dist/openapi.generate.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:jobs-seed": "node --import tsx --test \"src/common/jobs/*.test.ts\" \"src/common/database/seed/*.test.ts\" \"src/domains/support/jobs/*.test.ts\"",
    "coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"src/**/*.ts\" \"src/**/*.test.ts\"",
    "e2e": "node e2e/run-api-e2e.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const {rmSync}=require('node:fs'); for (const path of ['dist','tsconfig.tsbuildinfo']) rmSync(path,{recursive:true,force:true})\""
  },
  "dependencies": {
    "@hermes-swarm/core": "workspace:*",
    "@hermes-swarm/rbac": "workspace:*",
    "@hermes-swarm/rbac-api": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "pg": "^8.13.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2"
  },
  "nx": {
    "projectType": "application",
    "tags": ["type:app", "scope:backend"],
    "targets": {
      "dev": {
        "dependsOn": ["^build"]
      },
      "openapi:generate": {
        "dependsOn": ["build"],
        "command": "node dist/openapi.generate.js",
        "options": {
          "cwd": "apps/api"
        }
      },
      "coverage": {
        "command": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"src/**/*.ts\" \"src/**/*.test.ts\"",
        "options": {
          "cwd": "apps/api"
        }
      },
      "e2e": {
        "command": "node apps/api/e2e/run-api-e2e.mjs"
      }
    }
  }
}
