# ============================================
# Hermes Swarm — Development Environment
# ============================================
# Copy to project root .env (app runtime config):
#   cp .env.example .env
#
# Copy to devenv/.env (Docker services):
#   cp .env.example devenv/.env
#   (adjust ports if defaults are already in use)

# ---- App Runtime ----
API_PORT=3200
CORS_ORIGIN=http://localhost:3100
NEXT_PUBLIC_API_BASE_URL=http://localhost:3200/api
# Non-production only by default. Set false to disable default admin password recovery.
ALLOW_DEFAULT_ADMIN_RECOVERY=true
# Dedicated AES-256-GCM master key for parameters whose type is "secret".
# Use a long random value and keep it stable; changing it makes existing
# encrypted parameter values unreadable.
SETTINGS_ENCRYPTION_KEY=replace-with-a-long-random-settings-key
# Comma-separated IPs/CIDRs of the reverse proxies that connect directly to the
# API. Forwarded/X-Forwarded-For and CDN client-IP headers are ignored unless the
# TCP peer matches this list. The last trusted proxy must overwrite or sanitize
# incoming forwarding headers. Example for a local Next.js BFF:
# TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes_dev_pwd
POSTGRES_DB=hermes
POSTGRES_URL=postgresql://hermes:hermes_dev_pwd@localhost:5432/hermes
# Tenant traffic always uses the non-BYPASSRLS role provisioned by the
# development database bootstrap. Platform traffic uses the database owner.
POSTGRES_TENANT_URL=postgresql://hermes_tenant_app:hermes_tenant_dev_pwd@localhost:5432/hermes
POSTGRES_PLATFORM_URL=postgresql://hermes:hermes_dev_pwd@localhost:5432/hermes

# ---- Database Synchronization ----
# Schema changes are migration-only in every environment.
DATABASE_SYNCHRONIZE=false
# API startup never applies migrations. Keep false; deployment runs migration:run.
DATABASE_MIGRATIONS_RUN=false
# Validate the tenant and platform database roles during API startup.
DATABASE_STRICT_RLS=true
# Isolated database URL used only by tests when NODE_ENV=test.
# POSTGRES_TEST_URL=postgresql://hermes:hermes_dev_pwd@localhost:5432/hermes-test

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=hermes_redis_pwd
REDIS_URL=redis://:hermes_redis_pwd@localhost:6379

# ---- TypeORM Query Cache ----
TYPEORM_CACHE_ENABLED=true
TYPEORM_CACHE_DURATION_MS=30000
TYPEORM_CACHE_ALWAYS_ENABLED=false
TYPEORM_CACHE_IGNORE_ERRORS=true
