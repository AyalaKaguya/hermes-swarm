# ============================================
# Hermes Swarm — Development Environment
# ============================================
# Copy to project root .env (app runtime config):
#   cp .env.example .env
#
# Copy to docker/.env (Docker services):
#   cp .env.example docker/.env
#   (adjust ports if defaults are already in use)

# ---- App Runtime ----
API_PORT=3200
CORS_ORIGIN=http://localhost:3100
NEXT_PUBLIC_API_BASE_URL=http://localhost:3200/api
# Increase this only for high-latency development or test environments.
NEXT_PUBLIC_ADMIN_API_TIMEOUT_MS=30000
# Non-production only by default. Set false to disable default admin password recovery.
ALLOW_DEFAULT_ADMIN_RECOVERY=true
# Generate independent random values of at least 32 bytes for every secret.
# Production startup rejects missing, reused, or obvious placeholder values.
AUTH_SESSION_SECRET=replace-with-an-independent-random-auth-session-secret
AUTH_SESSION_KEY_ID=primary
# JSON object of retired key IDs to secrets; keep only during the session
# rotation window. Example: {"previous":"old-random-secret"}
AUTH_SESSION_PREVIOUS_KEYS={}
WEB_SESSION_SECRET=replace-with-an-independent-random-web-session-secret
INVITE_TOKEN_SECRET=replace-with-an-independent-random-invite-token-secret
PASSWORD_RESET_TOKEN_SECRET=replace-with-an-independent-random-password-reset-token-secret
# Dedicated AES-256-GCM keyring for encrypted settings. New writes use the
# active key ID; old keys remain read-only until values have been re-encrypted.
SETTINGS_ENCRYPTION_KEY=replace-with-a-long-random-settings-key
SETTINGS_ENCRYPTION_KEY_ID=primary
SETTINGS_PREVIOUS_ENCRYPTION_KEYS={}
# Comma-separated IPs/CIDRs of the reverse proxies that connect directly to the
# API. Forwarded/X-Forwarded-For and CDN client-IP headers are ignored unless the
# TCP peer matches this list. The last trusted proxy must overwrite or sanitize
# incoming forwarding headers. Example for a local Next.js BFF:
# TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes_dev_pwd
POSTGRES_DB=hermes
POSTGRES_URL=postgresql://hermes:hermes_dev_pwd@localhost:5432/hermes
# Optional strict RLS hardening. When both overrides are omitted, the workspace
# and platform datasources share POSTGRES_URL while keeping separate pools.
# POSTGRES_WORKSPACE_URL=postgresql://hermes_workspace_app:hermes_workspace_dev_pwd@localhost:5432/hermes
# POSTGRES_PLATFORM_URL=postgresql://hermes:hermes_dev_pwd@localhost:5432/hermes

# ---- Database Synchronization ----
# Schema changes are migration-only in every environment.
DATABASE_SYNCHRONIZE=false
# API startup never applies migrations. Keep false; deployment runs migration:run.
DATABASE_MIGRATIONS_RUN=false
# Opt in only when the two dedicated URLs above use isolated database roles.
DATABASE_STRICT_RLS=false
# Isolated database URL used only by tests when NODE_ENV=test.
# POSTGRES_TEST_URL=postgresql://hermes:hermes_dev_pwd@localhost:5432/hermes-test

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=hermes_redis_pwd
REDIS_URL=redis://:hermes_redis_pwd@localhost:6379

# ---- TypeORM Query Cache ----
TYPEORM_CACHE_ENABLED=true
TYPEORM_CACHE_DURATION_MS=30000
TYPEORM_CACHE_ALWAYS_ENABLED=false
TYPEORM_CACHE_IGNORE_ERRORS=true
