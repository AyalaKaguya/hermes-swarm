{
  "name": "@hermes-swarm/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./identity": {
      "types": "./dist/identity/index.d.ts",
      "import": "./dist/identity/index.js"
    },
    "./identity/permissions": {
      "types": "./dist/identity/permissions.d.ts",
      "import": "./dist/identity/permissions.js"
    },
    "./identity/entities": {
      "types": "./dist/identity/entities/index.d.ts",
      "import": "./dist/identity/entities/index.js"
    },
    "./mail": {
      "types": "./dist/mail/index.d.ts",
      "import": "./dist/mail/index.js"
    },
    "./mail/entities": {
      "types": "./dist/mail/entities/index.d.ts",
      "import": "./dist/mail/entities/index.js"
    },
    "./settings": {
      "types": "./dist/settings/index.d.ts",
      "import": "./dist/settings/index.js"
    },
    "./settings/definitions": {
      "types": "./dist/settings/definitions.d.ts",
      "import": "./dist/settings/definitions.js"
    },
    "./settings/effective-settings": {
      "types": "./dist/settings/effective-settings.d.ts",
      "import": "./dist/settings/effective-settings.js"
    },
    "./settings/entities": {
      "types": "./dist/settings/entities/index.d.ts",
      "import": "./dist/settings/entities/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"src/**/*.ts\" \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "typeorm": "^1.0.0"
  },
  "nx": {
    "targets": {
      "coverage": {
        "command": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"src/**/*.ts\" \"src/**/*.test.ts\"",
        "options": {
          "cwd": "packages/core"
        }
      }
    }
  }
}
