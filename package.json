{
  "name": "hermes-swarm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Hermes Swarm Monorepo",
  "scripts": {
    "build": "nx run-many --target=build",
    "test": "nx run-many --target=test",
    "lint": "nx run-many --target=lint",
    "clean": "nx run-many --target=clean",
    "graph": "nx graph"
  },
  "engines": {
    "node": ">=20.9",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
