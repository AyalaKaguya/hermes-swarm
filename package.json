    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.21",
    "@types/nodemailer": "^8.0.1",
    "nx": "23.0.1",
    "playwright": "^1.61.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "nx",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
