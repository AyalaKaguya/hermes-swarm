{
  "name": "hermes-swarm",
  "version": "0.0.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "description": "Hermes Swarm Monorepo",
  "scripts": {
    "build": "nx run-many --target=build",
    "test": "nx run-many --target=test",
    "coverage": "nx run-many --target=coverage",
    "test:coverage": "nx run-many --target=coverage",
    "lint": "nx run-many --target=lint",
    "clean": "nx run-many --target=clean",
    "graph": "nx graph",
    "openapi:generate": "pnpm --filter @hermes-swarm/api openapi:generate",
    "seed:development": "pnpm nx run @hermes-swarm/api:seed:development",
    "verify:refactor": "node scripts/verify-refactor.mjs"
  },
  "engines": {
    "node": ">=20.9",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@nx/js": "23.0.1",
    "@types/handlebars": "^4.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.21",
    "@types/nodemailer": "^8.0.1",
    "nx": "23.0.1",
    "playwright": "^1.61.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "handlebars": "^4.7.9",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.1"
  }
}
